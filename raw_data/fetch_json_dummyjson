import urllib.request
import json

def fetch_and_save(url, out_path):
    request = urllib.request.Request(
        url,
        headers={"User-Agent": "Mozilla/5.0"}
    )

    with urllib.request.urlopen(request) as response:
            data = json.load(response)

    with open(out_path, "w", encoding="utf-8") as f:
            json.dump(data, f, indent=2)

    print(f"Saved {out_path}")


def main():
    carts_url = "https://dummyjson.com/carts?limit=0"
    users_url = "https://dummyjson.com/users?limit=0"
    products_url = "https://dummyjson.com/products?limit=0"

    fetch_and_save(carts_url, "carts.json")
    fetch_and_save(users_url, "users.json")
    fetch_and_save(products_url, "products.json")


if __name__ == "__main__":
    main()